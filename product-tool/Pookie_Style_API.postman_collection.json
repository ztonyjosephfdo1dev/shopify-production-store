                },
                { "key": "price", "value": "499", "type": "text" },
                { "key": "compare_at_price", "value": "899", "type": "text" },
                { "key": "sizes", "value": "S,M,L", "type": "text" },
                { "key": "category", "value": "single-piece", "type": "text" },
                { "key": "extra_prompt", "value": "Casual urban street vibe, modern confident poses", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{backend_url}}",
              "host": ["{{backend_url}}"]
            },
            "description": "Test with a western dress to verify:\n- dress_style should be 'western'\n- Background should be urban/minimal\n- Poses should be casual/confident"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Product created', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('Dress style detected', function() {",
                  "    var json = pm.response.json();",
                  "    console.log('Detected dress_style: ' + json.dress_style);",
                  "    console.log('AI analysis: ' + JSON.stringify(json.ai_analysis));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
