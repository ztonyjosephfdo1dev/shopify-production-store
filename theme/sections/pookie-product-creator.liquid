{% comment %}
  Pookie Style — AI Product Creator (v3)
  Two-step flow: Upload → Preview → Confirm
  Admin-only page section.
{% endcomment %}

{{ 'pookie-product-creator.css' | asset_url | stylesheet_tag }}

<section class="pookie-creator" data-section-id="{{ section.id }}">
  <div class="pookie-creator__container">
    <header class="pookie-creator__header">
      <h1 class="pookie-creator__title">{{ section.settings.heading }}</h1>
      <p class="pookie-creator__subtitle">{{ section.settings.subheading }}</p>
    </header>

    {%- comment -%} ========== SCREEN 1: UPLOAD FORM ========== {%- endcomment -%}
    <form id="pookie-creator-form" class="pookie-creator__form" enctype="multipart/form-data">
      {%- comment -%} Bulk Upload Toggle {%- endcomment -%}
      <div class="pookie-creator__field pookie-creator__bulk-toggle">
        <label class="pookie-creator__label">Upload Mode</label>
        <div class="pookie-creator__switch-row">
          <label class="pookie-creator__switch">
            <input type="checkbox" id="pookie-bulk-mode" />
            <span class="pookie-creator__switch-slider"></span>
          </label>
          <span id="pookie-bulk-label" class="pookie-creator__switch-text">Single Product</span>
        </div>
        <p class="pookie-creator__hint">Toggle ON for bulk upload — each image becomes a separate product with shared details.</p>
      </div>

      {%- comment -%} Image Upload {%- endcomment -%}
      <div class="pookie-creator__field">
        <label class="pookie-creator__label">
          Product Photos <span class="pookie-creator__required">*</span>
        </label>
        <p id="pookie-upload-hint" class="pookie-creator__hint">Upload 1-3 photos (phone camera, hanger, flat-lay, mannequin)</p>
        <div id="pookie-dropzone" class="pookie-creator__dropzone">
          <div class="pookie-creator__dropzone-content">
            <svg class="pookie-creator__upload-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <p>Drag & drop photos here or <span class="pookie-creator__browse">browse</span></p>
            <p id="pookie-dropzone-hint" class="pookie-creator__hint">JPG, PNG — max 10 MB each — up to 3 photos</p>
          </div>
          <input type="file" id="pookie-images" name="images" accept="image/jpeg,image/png,image/webp" multiple class="pookie-creator__file-input" />
        </div>
        <div id="pookie-previews" class="pookie-creator__previews"></div>
      </div>

      {%- comment -%} Price Fields {%- endcomment -%}
      <div class="pookie-creator__row">
        <div class="pookie-creator__field pookie-creator__field--half">
          <label class="pookie-creator__label" for="pookie-price">
            Selling Price (₹) <span class="pookie-creator__required">*</span>
          </label>
          <input type="number" id="pookie-price" name="price" class="pookie-creator__input" placeholder="599" min="1" required />
        </div>
        <div class="pookie-creator__field pookie-creator__field--half">
          <label class="pookie-creator__label" for="pookie-compare-price">
            Compare-at Price (₹) <span class="pookie-creator__required">*</span>
          </label>
          <input type="number" id="pookie-compare-price" name="compare_at_price" class="pookie-creator__input" placeholder="999" min="1" required />
        </div>
      </div>

      {%- comment -%} Sizes {%- endcomment -%}
      <div class="pookie-creator__field">
        <label class="pookie-creator__label">
          Sizes <span class="pookie-creator__required">*</span>
        </label>
        <div class="pookie-creator__sizes">
          {%- assign size_options = "S,M,L,XL,XXL,Free Size" | split: "," -%}
          {%- for size in size_options -%}
            <label class="pookie-creator__size-chip">
              <input type="checkbox" name="sizes" value="{{ size }}" class="pookie-creator__size-input" />
              <span class="pookie-creator__size-label">{{ size }}</span>
            </label>
          {%- endfor -%}
        </div>
      </div>

      {%- comment -%} Optional Fields {%- endcomment -%}
      <div class="pookie-creator__field" id="pookie-field-name">
        <label class="pookie-creator__label" for="pookie-name">Product Name <span class="pookie-creator__optional">(optional — AI generates if blank)</span></label>
        <input type="text" id="pookie-name" name="name" class="pookie-creator__input" placeholder="e.g., Emerald Green A-Line Kurti" />
      </div>

      <div class="pookie-creator__field" id="pookie-field-description">
        <label class="pookie-creator__label" for="pookie-description">Description / Notes <span class="pookie-creator__optional">(optional — AI uses to generate listing)</span></label>
        <textarea id="pookie-description" name="description" class="pookie-creator__textarea" rows="3" placeholder="Any details: fabric, occasion, special features..."></textarea>
        <label class="pookie-creator__checkbox-label" style="margin-top:8px;">
          <input type="checkbox" id="pookie-use-my-desc" name="use_my_description" value="true" />
          <span>Use my description as-is (skip AI rewrite)</span>
        </label>
      </div>

      <div class="pookie-creator__field">
        <label class="pookie-creator__label" for="pookie-category">Category <span class="pookie-creator__optional">(optional — AI auto-detects if blank)</span></label>
        <select id="pookie-category" name="category" class="pookie-creator__select">
          <option value="">AI will detect automatically</option>
          <optgroup label="Ethnic Wear">
            <option value="kurti">Kurti</option>
            <option value="kurti-set">Kurti Set</option>
            <option value="suits">Suits</option>
            <option value="indo-western">Indo-Western</option>
          </optgroup>
          <optgroup label="Western Wear">
            <option value="top-wear">Top Wear</option>
            <option value="tops">Tops</option>
            <option value="casual-top">Casual Top</option>
            <option value="korean-top">Korean Top</option>
            <option value="shirt">Shirt</option>
            <option value="blouse">Blouse</option>
            <option value="bodycon">Bodycon</option>
            <option value="fancy-crop-top">Crop Top</option>
          </optgroup>
          <optgroup label="Dresses & Gowns">
            <option value="single-piece">Single Piece / Dress</option>
            <option value="gown">Gown</option>
            <option value="maxi">Maxi</option>
            <option value="casual-maxi">Casual Maxi</option>
          </optgroup>
          <optgroup label="Sets & Bottoms">
            <option value="cord-set">Cord Set</option>
            <option value="bottom">Bottom</option>
            <option value="plazo">Palazzo</option>
            <option value="skirt">Skirt</option>
          </optgroup>
          <optgroup label="Innerwear">
            <option value="inners">Inners</option>
          </optgroup>
          <optgroup label="Beauty & Care">
            <option value="skin-care">Skin Care</option>
            <option value="face-wash">Face Wash</option>
            <option value="body-lotion">Body Lotion</option>
          </optgroup>
        </select>
      </div>

      {%- comment -%} Status {%- endcomment -%}
      <div class="pookie-creator__field">
        <label class="pookie-creator__label" for="pookie-status">Product Status</label>
        <select id="pookie-status" name="status" class="pookie-creator__select">
          <option value="DRAFT" selected>Draft (review before publishing)</option>
          <option value="ACTIVE">Active (publish immediately)</option>
        </select>
      </div>

      {%- comment -%} Inventory Quantity {%- endcomment -%}
      <div class="pookie-creator__field">
        <label class="pookie-creator__label" for="pookie-quantity">
          Inventory Quantity (per variant) <span class="pookie-creator__optional">(default: 1)</span>
        </label>
        <input type="number" id="pookie-quantity" name="quantity" class="pookie-creator__input" placeholder="1" min="1" max="9999" value="1" />
        <p class="pookie-creator__hint">Each size variant will be stocked with this quantity.</p>
      </div>

      {%- comment -%} Extra Styling Prompt {%- endcomment -%}
      <div class="pookie-creator__field" id="pookie-field-extra-prompt">
        <label class="pookie-creator__label" for="pookie-extra-prompt">Styling / Pose Instructions <span class="pookie-creator__optional">(optional)</span></label>
        <textarea id="pookie-extra-prompt" name="extra_prompt" class="pookie-creator__textarea" rows="2" placeholder="e.g., Show with traditional Indian poses, add floral accessories, evening party vibe..."></textarea>
      </div>

      {%- comment -%} Image Quality {%- endcomment -%}
      <div class="pookie-creator__field" id="pookie-field-image-quality">
        <label class="pookie-creator__label" for="pookie-image-quality">Image Quality</label>
        <select id="pookie-image-quality" name="image_quality" class="pookie-creator__select">
          <option value="low">Low — fastest (~₹1, quick preview)</option>
          <option value="medium" selected>Medium — recommended (~₹4, good detail)</option>
          <option value="high">High — premium (~₹17, best quality)</option>
        </select>
        <p class="pookie-creator__hint">Higher quality = better detail + longer generation time.</p>
      </div>

      {%- comment -%} Real Garment Photo Option {%- endcomment -%}
      <div class="pookie-creator__field" id="pookie-field-garment-photo">
        <label class="pookie-creator__label">Real Garment Photo (added as last product image)</label>
        <p class="pookie-creator__hint">Include the original garment photo alongside the AI-generated images on Shopify.</p>
        <div class="pookie-creator__radio-group">
          <label class="pookie-creator__radio-label">
            <input type="radio" name="garment_photo_option" value="auto" checked class="pookie-creator__radio-input" />
            <span>Use first uploaded photo automatically</span>
          </label>
          <label class="pookie-creator__radio-label">
            <input type="radio" name="garment_photo_option" value="manual" class="pookie-creator__radio-input" />
            <span>Upload a separate clean garment photo</span>
          </label>
          <label class="pookie-creator__radio-label">
            <input type="radio" name="garment_photo_option" value="skip" class="pookie-creator__radio-input" />
            <span>Skip — don't include real garment photo</span>
          </label>
        </div>
        <div id="pookie-garment-manual-upload" class="pookie-creator__manual-upload" style="display:none; margin-top: 10px;">
          <input type="file" id="pookie-garment-photo" name="garment_photo" accept="image/jpeg,image/png,image/webp" class="pookie-creator__file-input-inline" />
          <p class="pookie-creator__hint">Upload a clean, well-lit photo of the garment (max 10 MB).</p>
          <div id="pookie-garment-preview" class="pookie-creator__garment-preview"></div>
        </div>
      </div>

      <button type="submit" id="pookie-submit" class="pookie-creator__submit">
        <span class="pookie-creator__submit-text">Generate Preview</span>
        <span class="pookie-creator__submit-loading" style="display:none;">Processing...</span>
      </button>
    </form>

    {%- comment -%} ========== PROGRESS INDICATOR ========== {%- endcomment -%}
    <div id="pookie-progress" class="pookie-creator__progress" style="display:none;">
      <div class="pookie-creator__progress-bar">
        <div id="pookie-progress-fill" class="pookie-creator__progress-fill" style="width:0%"></div>
      </div>
      <p id="pookie-progress-text" class="pookie-creator__progress-text">Starting...</p>
    </div>

    {%- comment -%} ========== SCREEN 2: PREVIEW ========== {%- endcomment -%}
    <div id="pookie-preview-screen" class="pookie-creator__preview-screen" style="display:none;">
      <h2 style="text-align:center;margin-bottom:4px;">Preview — Review Before Creating</h2>
      <p style="text-align:center;color:#888;margin-bottom:24px;font-size:14px;">Review everything below. Edit the name or description if needed, then click "Create Product".</p>

      {%- comment -%} Generated Images {%- endcomment -%}
      <div class="pookie-creator__field">
        <label class="pookie-creator__label">AI Generated Images <span id="pookie-img-count" style="color:#888;font-weight:normal;"></span></label>
        <div id="pookie-vton-warning" style="display:none;background:#fff3cd;border:1px solid #ffc107;border-radius:8px;padding:12px 16px;margin-bottom:12px;font-size:14px;">
          ⚠️ <strong>AI image generation failed.</strong> The image below is your original upload.<br>
          <span style="color:#666;">This may be a temporary issue. Try again or check your OpenAI API key balance.</span>
        </div>
        <div id="pookie-preview-images" class="pookie-creator__preview-images" style="display:flex;gap:16px;flex-wrap:wrap;"></div>
      </div>

      {%- comment -%} Product Name (editable) {%- endcomment -%}
      <div class="pookie-creator__field">
        <label class="pookie-creator__label" for="pookie-preview-name">Product Name</label>
        <input type="text" id="pookie-preview-name" class="pookie-creator__input" />
      </div>

      {%- comment -%} Description (editable, with toggle) {%- endcomment -%}
      <div class="pookie-creator__field">
        <label class="pookie-creator__label">Description</label>
        <div id="pookie-preview-desc-toggle" style="margin-bottom:8px;display:flex;gap:12px;">
          <button type="button" id="pookie-desc-ai-btn" class="pookie-creator__toggle-btn pookie-creator__toggle-btn--active" onclick="window.__pookieUseAIDesc()">AI Generated</button>
          <button type="button" id="pookie-desc-my-btn" class="pookie-creator__toggle-btn" onclick="window.__pookieUseMyDesc()">My Description</button>
        </div>
        <div id="pookie-preview-desc-html" class="pookie-creator__desc-preview" style="background:#fafafa;padding:16px;border-radius:8px;border:1px solid #eee;min-height:60px;"></div>
        <textarea id="pookie-preview-desc-edit" class="pookie-creator__textarea" rows="4" style="display:none;margin-top:8px;"></textarea>
        <label class="pookie-creator__checkbox-label" style="margin-top:8px;">
          <input type="checkbox" id="pookie-preview-desc-edit-toggle" onchange="window.__pookieToggleDescEdit(this.checked)" />
          <span>Edit description manually</span>
        </label>
      </div>

      {%- comment -%} Tags {%- endcomment -%}
      <div class="pookie-creator__field">
        <label class="pookie-creator__label">Tags <span style="color:#888;font-weight:normal;">(<span id="pookie-preview-tag-count">0</span> tags)</span></label>
        <div id="pookie-preview-tags" class="pookie-creator__tags-preview" style="display:flex;flex-wrap:wrap;gap:6px;"></div>
      </div>

      {%- comment -%} AI Analysis {%- endcomment -%}
      <div class="pookie-creator__field">
        <label class="pookie-creator__label">AI Analysis</label>
        <div id="pookie-preview-analysis" style="display:grid;grid-template-columns:1fr 1fr;gap:8px;font-size:14px;"></div>
      </div>

      {%- comment -%} Price / Size / Collection summary {%- endcomment -%}
      <div class="pookie-creator__field">
        <label class="pookie-creator__label">Product Details</label>
        <div id="pookie-preview-details" style="font-size:14px;line-height:1.8;"></div>
        <div style="margin-top:12px;display:flex;gap:16px;align-items:center;">
          <label style="font-weight:600;font-size:14px;">Status:</label>
          <select id="pookie-preview-status" class="pookie-creator__select" style="width:auto;min-width:180px;">
            <option value="DRAFT">Draft (review before publishing)</option>
            <option value="ACTIVE">Active (publish immediately)</option>
          </select>
        </div>
        <div style="margin-top:8px;display:flex;gap:16px;align-items:center;">
          <label style="font-weight:600;font-size:14px;">Inventory (per variant):</label>
          <input type="number" id="pookie-preview-quantity" class="pookie-creator__input" style="width:80px;" min="1" max="9999" value="1" />
          <span style="font-size:13px;color:#888;">units per size variant</span>
        </div>
      </div>

      {%- comment -%} Action Buttons {%- endcomment -%}
      <div style="display:flex;gap:12px;margin-top:24px;">
        <button type="button" id="pookie-back-btn" class="pookie-creator__submit" style="background:#666;" onclick="window.__pookieBackToForm()">Back to Edit</button>
        <button type="button" id="pookie-confirm-btn" class="pookie-creator__submit" onclick="window.__pookieConfirm()">Create Product on Shopify</button>
      </div>
    </div>

    {%- comment -%} ========== SCREEN 3: SUCCESS ========== {%- endcomment -%}
    <div id="pookie-success" class="pookie-creator__success" style="display:none;">
      <div class="pookie-creator__success-icon">&#x2705;</div>
      <h2>Product Created Successfully!</h2>
      <div id="pookie-single-result">
        <p id="pookie-success-name" class="pookie-creator__success-name"></p>
        <div class="pookie-creator__success-links">
          <a id="pookie-admin-link" href="#" target="_blank" class="pookie-creator__link pookie-creator__link--admin">View in Shopify Admin &rarr;</a>
          <a id="pookie-store-link" href="#" target="_blank" class="pookie-creator__link pookie-creator__link--store">View on Store &rarr;</a>
        </div>
        <div id="pookie-success-details" class="pookie-creator__success-details"></div>
      </div>
      <div id="pookie-bulk-results" class="pookie-bulk-results" style="display:none;"></div>
      <button id="pookie-create-another" class="pookie-creator__submit pookie-creator__submit--another">Create Another Product</button>
    </div>

    {%- comment -%} ========== ERROR MESSAGE ========== {%- endcomment -%}
    <div id="pookie-error" class="pookie-creator__error" style="display:none;">
      <div class="pookie-creator__error-icon">&#x274C;</div>
      <h2>Something went wrong</h2>
      <p id="pookie-error-text"></p>
      <button id="pookie-retry" class="pookie-creator__submit">Try Again</button>
    </div>
  </div>
</section>

<style>
  .pookie-creator__toggle-btn {
    padding: 6px 16px; border-radius: 20px; border: 1px solid #ddd;
    background: #fff; cursor: pointer; font-size: 13px; transition: all .2s;
  }
  .pookie-creator__toggle-btn--active {
    background: #111; color: #fff; border-color: #111;
  }
  .pookie-creator__tags-preview .tag-chip {
    background: #f3f3f3; padding: 4px 10px; border-radius: 12px;
    font-size: 12px; color: #444;
  }
  .pookie-creator__preview-images img {
    max-width: 300px; border-radius: 8px; border: 1px solid #eee;
  }
  .pookie-creator__preview-images .img-wrap {
    text-align: center;
  }
  .pookie-creator__preview-images .img-label {
    font-size: 12px; color: #888; margin-top: 4px;
  }
  .pookie-creator__checkbox-label {
    display: flex; align-items: center; gap: 8px; font-size: 14px; color: #555; cursor: pointer;
  }
  .pookie-creator__checkbox-label input[type="checkbox"] {
    width: 16px; height: 16px; accent-color: #111;
  }
  .pookie-creator__desc-preview { font-size: 14px; line-height: 1.6; color: #333; }
</style>

<script>
(function() {
  'use strict';

  var BACKEND_URL = '{{ section.settings.backend_url }}' || 'https://asia-south1-pookie-style-automation.cloudfunctions.net/create-product';
  var form = document.getElementById('pookie-creator-form');
  var fileInput = document.getElementById('pookie-images');
  var dropzone = document.getElementById('pookie-dropzone');
  var previews = document.getElementById('pookie-previews');
  var progressDiv = document.getElementById('pookie-progress');
  var progressFill = document.getElementById('pookie-progress-fill');
  var progressText = document.getElementById('pookie-progress-text');
  var previewScreen = document.getElementById('pookie-preview-screen');
  var successDiv = document.getElementById('pookie-success');
  var errorDiv = document.getElementById('pookie-error');
  var selectedFiles = [];
  var previewData = null; /* Stores backend response for confirm step */
  var manualGarmentFile = null; /* Separate garment photo for manual upload */
  var isBulkMode = false;

  /* --- Bulk Mode Toggle --- */
  var bulkToggle = document.getElementById('pookie-bulk-mode');
  var bulkLabel = document.getElementById('pookie-bulk-label');
  if (bulkToggle) {
    bulkToggle.addEventListener('change', function() {
      isBulkMode = this.checked;
      bulkLabel.textContent = isBulkMode ? 'Bulk Upload \u2014 each photo = 1 product' : 'Single Product';
      /* All form fields stay visible — they apply to every product */
      var uploadHint = document.getElementById('pookie-upload-hint');
      if (uploadHint) uploadHint.textContent = isBulkMode
        ? 'Upload up to 20 photos \u2014 each becomes a separate product'
        : 'Upload 1-3 photos (phone camera, hanger, flat-lay, mannequin)';
      var dropzoneHint = document.getElementById('pookie-dropzone-hint');
      if (dropzoneHint) dropzoneHint.textContent = isBulkMode
        ? 'JPG, PNG \u2014 max 10 MB each \u2014 up to 20 photos'
        : 'JPG, PNG \u2014 max 10 MB each \u2014 up to 3 photos';
      selectedFiles = [];
      renderPreviews();
      updateSubmitButton();
    });
  }
  function updateSubmitButton() {
    var txt = document.querySelector('.pookie-creator__submit-text');
    if (!txt) return;
    if (isBulkMode) {
      txt.textContent = selectedFiles.length > 0
        ? 'Create ' + selectedFiles.length + ' Product' + (selectedFiles.length !== 1 ? 's' : '')
        : 'Create Products';
    } else {
      txt.textContent = 'Generate Preview';
    }
  }

  /* --- Garment Photo Radio Toggle --- */
  var garmentRadios = document.querySelectorAll('input[name="garment_photo_option"]');
  var garmentManualDiv = document.getElementById('pookie-garment-manual-upload');
  var garmentFileInput = document.getElementById('pookie-garment-photo');
  var garmentPreviewDiv = document.getElementById('pookie-garment-preview');

  garmentRadios.forEach(function(radio) {
    radio.addEventListener('change', function() {
      if (this.value === 'manual') {
        garmentManualDiv.style.display = 'block';
      } else {
        garmentManualDiv.style.display = 'none';
        manualGarmentFile = null;
        garmentPreviewDiv.innerHTML = '';
      }
    });
  });

  if (garmentFileInput) {
    garmentFileInput.addEventListener('change', function() {
      var file = garmentFileInput.files[0];
      if (file) {
        if (file.size > 10 * 1024 * 1024) {
          alert('Garment photo must be under 10 MB.');
          garmentFileInput.value = '';
          return;
        }
        manualGarmentFile = file;
        garmentPreviewDiv.innerHTML = '';
        var img = document.createElement('img');
        img.src = URL.createObjectURL(file);
        img.alt = 'Garment photo preview';
        img.style.maxWidth = '120px';
        img.style.borderRadius = '8px';
        img.style.marginTop = '8px';
        garmentPreviewDiv.appendChild(img);
      }
    });
  }

  /* --- Drag & Drop --- */
  dropzone.addEventListener('click', function(e) {
    if (e.target === fileInput) return;
    fileInput.click();
  });
  dropzone.addEventListener('dragover', function(e) {
    e.preventDefault();
    dropzone.classList.add('pookie-creator__dropzone--active');
  });
  dropzone.addEventListener('dragleave', function() {
    dropzone.classList.remove('pookie-creator__dropzone--active');
  });
  dropzone.addEventListener('drop', function(e) {
    e.preventDefault();
    dropzone.classList.remove('pookie-creator__dropzone--active');
    handleFiles(e.dataTransfer.files);
  });
  fileInput.addEventListener('change', function() { handleFiles(fileInput.files); });

  function handleFiles(files) {
    var maxFiles = isBulkMode ? 20 : 3;
    var newFiles = Array.from(files).slice(0, maxFiles - selectedFiles.length);
    newFiles.forEach(function(file) {
      if (selectedFiles.length >= maxFiles) return;
      if (file.size > 10 * 1024 * 1024) {
        alert(file.name + ' is larger than 10 MB.');
        return;
      }
      selectedFiles.push(file);
    });
    renderPreviews();
    updateSubmitButton();
  }

  function renderPreviews() {
    previews.innerHTML = '';
    selectedFiles.forEach(function(file, idx) {
      var wrap = document.createElement('div');
      wrap.className = 'pookie-creator__preview';
      var img = document.createElement('img');
      img.src = URL.createObjectURL(file);
      img.alt = 'Preview ' + (idx + 1);
      var removeBtn = document.createElement('button');
      removeBtn.className = 'pookie-creator__preview-remove';
      removeBtn.textContent = '\u00d7';
      removeBtn.type = 'button';
      removeBtn.addEventListener('click', function() {
        selectedFiles.splice(idx, 1);
        renderPreviews();
        updateSubmitButton();
      });
      wrap.appendChild(img);
      wrap.appendChild(removeBtn);
      if (isBulkMode) {
        var flabel = document.createElement('div');
        flabel.style.cssText = 'font-size:10px;color:#888;text-align:center;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100px;';
        flabel.textContent = file.name;
        wrap.appendChild(flabel);
      }
      previews.appendChild(wrap);
    });
  }

  /* --- Progress Animation --- */
  var progressSteps = [
    { pct: 10, text: 'Uploading images...' },
    { pct: 25, text: 'AI analyzing garment photos...' },
    { pct: 40, text: 'Generating product name, description & tags...' },
    { pct: 55, text: 'Creating 6-pose model lookbook grid...' },
    { pct: 70, text: 'This takes 15-30s depending on quality...' },
    { pct: 82, text: 'Cropping hero image & building collage...' },
    { pct: 92, text: 'Almost done — preparing preview...' },
    { pct: 95, text: 'Finalizing...' },
  ];

  function animateProgress() {
    var i = 0;
    var interval = setInterval(function() {
      if (i >= progressSteps.length) { clearInterval(interval); return; }
      progressFill.style.width = progressSteps[i].pct + '%';
      progressText.textContent = progressSteps[i].text;
      i++;
    }, 4000);
    return interval;
  }

  /* --- SCREEN MANAGEMENT --- */
  function showScreen(screen) {
    form.style.display = screen === 'form' ? 'block' : 'none';
    progressDiv.style.display = screen === 'progress' ? 'block' : 'none';
    previewScreen.style.display = screen === 'preview' ? 'block' : 'none';
    successDiv.style.display = screen === 'success' ? 'block' : 'none';
    errorDiv.style.display = screen === 'error' ? 'block' : 'none';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  /* --- SUBMIT FORM --- */
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    if (isBulkMode) { handleBulkSubmit(); return; }
    if (selectedFiles.length === 0) { alert('Please upload at least 1 photo.'); return; }
    var checkedSizes = form.querySelectorAll('input[name="sizes"]:checked');
    if (checkedSizes.length === 0) { alert('Please select at least one size.'); return; }
    if (!BACKEND_URL) { alert('Backend URL not configured.'); return; }

    var sizes = [];
    checkedSizes.forEach(function(cb) { sizes.push(cb.value); });

    var fd = new FormData();
    selectedFiles.forEach(function(f) { fd.append('images', f); });
    fd.append('price', form.querySelector('#pookie-price').value);
    fd.append('compare_at_price', form.querySelector('#pookie-compare-price').value);
    fd.append('sizes', sizes.join(','));
    fd.append('name', form.querySelector('#pookie-name').value);
    fd.append('description', form.querySelector('#pookie-description').value);
    fd.append('category', form.querySelector('#pookie-category').value);
    fd.append('status', form.querySelector('#pookie-status').value);
    fd.append('extra_prompt', form.querySelector('#pookie-extra-prompt').value);
    fd.append('image_quality', form.querySelector('#pookie-image-quality').value);
    fd.append('quantity', form.querySelector('#pookie-quantity').value);
    fd.append('use_my_description', document.getElementById('pookie-use-my-desc').checked ? 'true' : 'false');

    /* Garment photo option */
    var garmentOption = form.querySelector('input[name="garment_photo_option"]:checked');
    fd.append('garment_photo_option', garmentOption ? garmentOption.value : 'auto');
    if (garmentOption && garmentOption.value === 'manual' && manualGarmentFile) {
      fd.append('garment_photo', manualGarmentFile);
    }

    showScreen('progress');
    progressFill.style.width = '5%';
    progressText.textContent = 'Starting...';
    var progressInterval = animateProgress();

    fetch(BACKEND_URL + '?action=preview', { method: 'POST', body: fd })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        clearInterval(progressInterval);
        if (data.success && data.preview) {
          previewData = data.preview;
          renderPreviewScreen(data.preview);
          showScreen('preview');
        } else {
          showScreen('error');
          document.getElementById('pookie-error-text').textContent = data.error || 'Unknown error.';
        }
      })
      .catch(function(err) {
        clearInterval(progressInterval);
        showScreen('error');
        document.getElementById('pookie-error-text').textContent = 'Network error: ' + err.message;
      });
  });

  /* --- RENDER PREVIEW SCREEN --- */
  function renderPreviewScreen(p) {
    /* Images */
    var imgContainer = document.getElementById('pookie-preview-images');
    imgContainer.innerHTML = '';
    var images = p.images || [];

    /* Show/hide VTON failure warning */
    var warning = document.getElementById('pookie-vton-warning');
    var imgCount = document.getElementById('pookie-img-count');
    if (p.vton_failed) {
      warning.style.display = 'block';
      imgCount.textContent = '(generation failed)';
    } else {
      warning.style.display = 'none';
      imgCount.textContent = '(' + images.length + ' poses generated)';
    }

    images.forEach(function(img) {
      var wrap = document.createElement('div');
      wrap.className = 'img-wrap';
      var el = document.createElement('img');
      el.src = 'data:image/jpeg;base64,' + img.base64;
      el.alt = img.label;
      var lbl = document.createElement('div');
      lbl.className = 'img-label';
      lbl.textContent = img.label;
      wrap.appendChild(el);
      wrap.appendChild(lbl);
      imgContainer.appendChild(wrap);
    });

    /* Name */
    document.getElementById('pookie-preview-name').value = p.product_name || '';

    /* Description */
    window.__pookieAIDesc = p.ai_description || p.description_html || '';
    window.__pookieMyDesc = document.getElementById('pookie-description').value || '';
    document.getElementById('pookie-preview-desc-html').innerHTML = p.description_html || '';
    document.getElementById('pookie-preview-desc-edit').value = p.description_html || '';
    /* Reset toggle */
    document.getElementById('pookie-desc-ai-btn').classList.add('pookie-creator__toggle-btn--active');
    document.getElementById('pookie-desc-my-btn').classList.remove('pookie-creator__toggle-btn--active');
    document.getElementById('pookie-preview-desc-edit-toggle').checked = false;
    document.getElementById('pookie-preview-desc-edit').style.display = 'none';

    /* Tags */
    var tagsDiv = document.getElementById('pookie-preview-tags');
    tagsDiv.innerHTML = '';
    var tags = p.tags || [];
    tags.forEach(function(tag) {
      var chip = document.createElement('span');
      chip.className = 'tag-chip';
      chip.textContent = tag;
      tagsDiv.appendChild(chip);
    });
    document.getElementById('pookie-preview-tag-count').textContent = tags.length;

    /* AI Analysis */
    var analysisDiv = document.getElementById('pookie-preview-analysis');
    var ai = p.ai_analysis || {};
    analysisDiv.innerHTML = '';
    var fields = [
      ['Type', ai.garment_type], ['Color', ai.color],
      ['Fabric', ai.fabric], ['Style', ai.dress_style],
      ['Occasion', ai.occasion], ['Persona', ai.target_persona],
      ['Styling Tip', ai.styling_tip]
    ];
    fields.forEach(function(f) {
      if (f[1]) {
        analysisDiv.innerHTML += '<div><strong>' + f[0] + ':</strong> ' + f[1] + '</div>';
      }
    });

    /* Details summary */
    var detailsDiv = document.getElementById('pookie-preview-details');
    detailsDiv.innerHTML =
      '<strong>Price:</strong> &#x20B9;' + p.price + ' <span style="color:#888;text-decoration:line-through;">&#x20B9;' + p.compare_at_price + '</span><br>' +
      '<strong>Sizes:</strong> ' + (p.sizes || []).join(', ') + '<br>' +
      '<strong>Collections:</strong> ' + (p.collections && p.collections.length ? p.collections.join(', ') : 'None') + '<br>' +
      '<strong>SEO Title:</strong> ' + (p.seo_title || '') + '<br>' +
      '<strong>Meta:</strong> ' + (p.seo_description || '');

    /* Set editable status dropdown */
    var statusDropdown = document.getElementById('pookie-preview-status');
    if (statusDropdown) statusDropdown.value = p.status || 'DRAFT';

    /* Set editable quantity */
    var qtyInput = document.getElementById('pookie-preview-quantity');
    if (qtyInput) qtyInput.value = p.quantity || 1;
  }

  /* --- Description toggle helpers (exposed on window for onclick) --- */
  window.__pookieUseAIDesc = function() {
    document.getElementById('pookie-preview-desc-html').innerHTML = window.__pookieAIDesc;
    document.getElementById('pookie-preview-desc-edit').value = window.__pookieAIDesc;
    document.getElementById('pookie-desc-ai-btn').classList.add('pookie-creator__toggle-btn--active');
    document.getElementById('pookie-desc-my-btn').classList.remove('pookie-creator__toggle-btn--active');
  };
  window.__pookieUseMyDesc = function() {
    var myText = window.__pookieMyDesc || '';
    var html = '<p>' + myText + '</p>';
    document.getElementById('pookie-preview-desc-html').innerHTML = html;
    document.getElementById('pookie-preview-desc-edit').value = html;
    document.getElementById('pookie-desc-ai-btn').classList.remove('pookie-creator__toggle-btn--active');
    document.getElementById('pookie-desc-my-btn').classList.add('pookie-creator__toggle-btn--active');
  };
  window.__pookieToggleDescEdit = function(checked) {
    var htmlDiv = document.getElementById('pookie-preview-desc-html');
    var editArea = document.getElementById('pookie-preview-desc-edit');
    if (checked) {
      editArea.value = htmlDiv.innerHTML;
      editArea.style.display = 'block';
      htmlDiv.style.display = 'none';
    } else {
      htmlDiv.innerHTML = editArea.value;
      editArea.style.display = 'none';
      htmlDiv.style.display = 'block';
    }
  };

  /* --- BACK TO FORM --- */
  window.__pookieBackToForm = function() {
    showScreen('form');
  };

  /* --- STEP 2: CONFIRM → CREATE ON SHOPIFY --- */
  window.__pookieConfirm = function() {
    if (!previewData) { alert('No preview data.'); return; }

    var confirmBtn = document.getElementById('pookie-confirm-btn');
    confirmBtn.disabled = true;
    confirmBtn.textContent = 'Creating on Shopify...';

    /* Pick final description: either from edit textarea or from rendered HTML */
    var editArea = document.getElementById('pookie-preview-desc-edit');
    var htmlDiv = document.getElementById('pookie-preview-desc-html');
    var finalDesc = editArea.style.display !== 'none' ? editArea.value : htmlDiv.innerHTML;

    var payload = {
      product_name: document.getElementById('pookie-preview-name').value || previewData.product_name,
      description_html: finalDesc,
      tags: previewData.tags,
      seo_title: previewData.seo_title,
      seo_description: previewData.seo_description,
      product_type: previewData.product_type,
      status: document.getElementById('pookie-preview-status').value || previewData.status || 'DRAFT',
      category: previewData.category || '',
      quantity: parseInt(document.getElementById('pookie-preview-quantity').value) || 1,
      sizes: previewData.sizes,
      price: previewData.price,
      compare_at_price: previewData.compare_at_price,
      collections: previewData.collections,
      images: previewData.images,
    };

    fetch(BACKEND_URL + '?action=confirm', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        confirmBtn.disabled = false;
        confirmBtn.textContent = 'Create Product on Shopify';

        if (data.success) {
          var sr = document.getElementById('pookie-single-result');
          var br = document.getElementById('pookie-bulk-results');
          if (sr) sr.style.display = '';
          if (br) br.style.display = 'none';
          document.querySelector('.pookie-creator__success-icon').textContent = '\u2705';
          document.querySelector('.pookie-creator__success h2').textContent = 'Product Created Successfully!';
          showScreen('success');
          document.getElementById('pookie-success-name').textContent = data.product_name || 'Product';
          document.getElementById('pookie-admin-link').href = data.admin_url || '#';
          document.getElementById('pookie-store-link').href = data.product_url || '#';
          var details = '';
          if (data.images_uploaded) details += 'Images: ' + data.images_uploaded + '<br>';
          if (data.tags_count) details += 'Tags: ' + data.tags_count + '<br>';
          if (data.collections_assigned && data.collections_assigned.length)
            details += 'Collections: ' + data.collections_assigned.join(', ') + '<br>';
          document.getElementById('pookie-success-details').innerHTML = details;
        } else {
          showScreen('error');
          document.getElementById('pookie-error-text').textContent = data.error || 'Unknown error.';
        }
      })
      .catch(function(err) {
        confirmBtn.disabled = false;
        confirmBtn.textContent = 'Create Product on Shopify';
        showScreen('error');
        document.getElementById('pookie-error-text').textContent = 'Network error: ' + err.message;
      });
  };

  /* ====================================================================
     BULK UPLOAD \u2014 each image = 1 product
     ==================================================================== */
  function sleep(ms) { return new Promise(function(r) { setTimeout(r, ms); }); }

  async function handleBulkSubmit() {
    if (selectedFiles.length === 0) { alert('Please upload at least 1 photo.'); return; }
    var checkedSizes = form.querySelectorAll('input[name="sizes"]:checked');
    if (checkedSizes.length === 0) { alert('Please select at least one size.'); return; }
    if (!BACKEND_URL) { alert('Backend URL not configured.'); return; }
    var sizes = [];
    checkedSizes.forEach(function(cb) { sizes.push(cb.value); });

    /* Collect shared form values once */
    var sharedFields = {
      price: form.querySelector('#pookie-price').value,
      compare_at_price: form.querySelector('#pookie-compare-price').value,
      sizes: sizes.join(','),
      name: form.querySelector('#pookie-name').value,
      description: form.querySelector('#pookie-description').value,
      category: form.querySelector('#pookie-category').value,
      status: form.querySelector('#pookie-status').value,
      extra_prompt: form.querySelector('#pookie-extra-prompt').value,
      image_quality: form.querySelector('#pookie-image-quality').value,
      quantity: form.querySelector('#pookie-quantity').value,
      use_my_description: document.getElementById('pookie-use-my-desc').checked ? 'true' : 'false',
      garment_photo_option: (form.querySelector('input[name="garment_photo_option"]:checked') || {}).value || 'auto'
    };

    var total = selectedFiles.length;
    showScreen('progress');
    progressFill.style.width = '0%';
    progressText.textContent = 'Starting bulk creation (' + total + ' products)\u2026';
    var results = [], succeeded = 0, failed = 0;

    for (var i = 0; i < total; i++) {
      var fname = selectedFiles[i].name;

      /* ---- Step 1: Preview (AI text + 6-pose grid) ---- */
      progressText.textContent = '(' + (i + 1) + '/' + total + ') \uD83C\uDFA8 Generating AI images: ' + fname + '\u2026';
      progressFill.style.width = Math.round(((i + 0.2) / total) * 100) + '%';

      var fd = new FormData();
      fd.append('images', selectedFiles[i]);
      Object.keys(sharedFields).forEach(function(k) { fd.append(k, sharedFields[k]); });
      if (sharedFields.garment_photo_option === 'manual' && manualGarmentFile) {
        fd.append('garment_photo', manualGarmentFile);
      }

      var previewOk = false, confirmOk = false, productData = null;
      try {
        var prevRes = await fetch(BACKEND_URL + '?action=preview', { method: 'POST', body: fd });
        var prevData = await prevRes.json();
        if (!prevData.success || !prevData.preview) {
          throw new Error(prevData.error || 'AI generation failed');
        }
        previewOk = true;

        /* ---- Step 2: Confirm (upload + create on Shopify) ---- */
        progressText.textContent = '(' + (i + 1) + '/' + total + ') \uD83D\uDED2 Creating on Shopify: ' + (prevData.preview.product_name || fname) + '\u2026';
        progressFill.style.width = Math.round(((i + 0.7) / total) * 100) + '%';

        var payload = {
          product_name: prevData.preview.product_name,
          description_html: prevData.preview.description_html,
          tags: prevData.preview.tags,
          seo_title: prevData.preview.seo_title,
          seo_description: prevData.preview.seo_description,
          product_type: prevData.preview.product_type,
          status: 'DRAFT', /* Bulk always creates as Draft for review */
          category: prevData.preview.category || sharedFields.category,
          quantity: parseInt(sharedFields.quantity) || 1,
          sizes: prevData.preview.sizes,
          price: prevData.preview.price,
          compare_at_price: prevData.preview.compare_at_price,
          collections: prevData.preview.collections,
          images: prevData.preview.images
        };

        var confRes = await fetch(BACKEND_URL + '?action=confirm', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        var confData = await confRes.json();
        if (!confData.success) {
          throw new Error(confData.error || 'Shopify creation failed');
        }
        confirmOk = true;
        productData = confData;
        succeeded++;
        results.push(confData);

      } catch (err) {
        failed++;
        var stage = previewOk ? 'Shopify creation' : 'AI generation';
        var errMsg = err.message || 'Unknown error';
        /* Show user-friendly rate-limit message */
        if (errMsg.indexOf('429') !== -1 || errMsg.toLowerCase().indexOf('rate') !== -1) {
          errMsg = 'API rate limit hit \u2014 please try again with fewer products or wait a few minutes.';
        } else if (errMsg.indexOf('timeout') !== -1 || errMsg.indexOf('Timeout') !== -1) {
          errMsg = 'Request timed out \u2014 the server took too long to respond.';
        } else if (errMsg.indexOf('NetworkError') !== -1 || errMsg.indexOf('Failed to fetch') !== -1) {
          errMsg = 'Network error \u2014 check your internet connection.';
        }
        results.push({ success: false, error: stage + ': ' + errMsg, filename: fname });
      }

      progressFill.style.width = Math.round(((i + 1) / total) * 100) + '%';

      /* 3-second delay between products to avoid API rate limits */
      if (i < total - 1) {
        progressText.textContent = '(' + (i + 1) + '/' + total + ') \u2705 Done \u2014 waiting 3s before next\u2026';
        await sleep(3000);
      }
    }

    progressText.textContent = 'Done! ' + succeeded + ' created' + (failed > 0 ? ', ' + failed + ' failed' : '') + '.';
    renderBulkSuccess(results, succeeded, failed, total);
    showScreen('success');
  }

  function renderBulkSuccess(results, succeeded, failed, total) {
    var sr = document.getElementById('pookie-single-result');
    var br = document.getElementById('pookie-bulk-results');
    if (sr) sr.style.display = 'none';
    if (br) br.style.display = 'block';
    var icon = document.querySelector('.pookie-creator__success-icon');
    var heading = document.querySelector('.pookie-creator__success h2');
    if (icon) icon.textContent = failed === 0 ? '\u2705' : '\u26A0\uFE0F';
    if (heading) heading.textContent = succeeded + ' of ' + total + ' Products Created' + (failed === 0 ? '!' : '');
    var html = '';
    results.forEach(function(r, idx) {
      if (r.success) {
        html += '<div class="pookie-bulk-item pookie-bulk-item--ok">'
          + '<span class="pookie-bulk-num">' + (idx + 1) + '</span>'
          + '<span class="pookie-bulk-name">' + r.product_name + '</span>'
          + '<span class="pookie-bulk-links">'
          + '<a href="' + r.admin_url + '" target="_blank">Admin</a>'
          + '<a href="' + r.product_url + '" target="_blank">Store</a>'
          + '</span></div>';
      } else {
        html += '<div class="pookie-bulk-item pookie-bulk-item--fail">'
          + '<span class="pookie-bulk-num">' + (idx + 1) + '</span>'
          + '<span class="pookie-bulk-name">' + (r.filename || 'Unknown') + '</span>'
          + '<span class="pookie-bulk-error">\u274C ' + (r.error || 'Failed') + '</span></div>';
      }
    });
    if (br) br.innerHTML = html;
  }

  /* --- Create Another --- */
  document.getElementById('pookie-create-another').addEventListener('click', function() {
    previewData = null;
    isBulkMode = false;
    if (bulkToggle) bulkToggle.checked = false;
    if (bulkLabel) bulkLabel.textContent = 'Single Product';
    var uploadHint = document.getElementById('pookie-upload-hint');
    if (uploadHint) uploadHint.textContent = 'Upload 1-3 photos (phone camera, hanger, flat-lay, mannequin)';
    var dropzoneHint = document.getElementById('pookie-dropzone-hint');
    if (dropzoneHint) dropzoneHint.textContent = 'JPG, PNG \u2014 max 10 MB each \u2014 up to 3 photos';
    showScreen('form');
    form.reset();
    selectedFiles = [];
    manualGarmentFile = null;
    previews.innerHTML = '';
    if (garmentPreviewDiv) garmentPreviewDiv.innerHTML = '';
    if (garmentManualDiv) garmentManualDiv.style.display = 'none';
    updateSubmitButton();
  });

  /* --- Retry --- */
  document.getElementById('pookie-retry').addEventListener('click', function() {
    showScreen('form');
  });
})();
</script>

{% schema %}
{
  "name": "Product Creator",
  "tag": "section",
  "class": "pookie-product-creator",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Create New Product"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Upload a photo and let AI do the rest. Product will be saved as Draft."
    },
    {
      "type": "url",
      "id": "backend_url",
      "label": "Backend URL",
      "info": "Google Cloud Function URL (e.g., https://asia-south1-pookie-style-automation.cloudfunctions.net/create-product)"
    }
  ],
  "presets": [
    {
      "name": "Product Creator"
    }
  ]
}
{% endschema %}
