<section
  class="pookie-hero"
  data-section-id="{{ section.id }}"
  role="region"
  aria-label="{{ 'sections.pookie_hero.aria_label' | t }}"
>
  <div
    class="pookie-hero__slider"
    data-auto-rotate="{{ section.settings.auto_rotate }}"
    data-speed="{{ section.settings.speed }}"
  >
    {% for block in section.blocks %}
      <div
        class="pookie-hero__slide {% if forloop.first %}is-active{% endif %}"
        data-index="{{ forloop.index0 }}"
        role="group"
        aria-roledescription="slide"
        aria-label="{{ 'sections.pookie_hero.slide_of' | t: current: forloop.index, total: section.blocks.size }}"
        {{ block.shopify_attributes }}
      >
        <div class="pookie-hero__media">
          {% if block.settings.image %}
            {{
              block.settings.image
              | image_url: width: 1920
              | image_tag:
                class: 'pookie-hero__img',
                loading: 'eager',
                sizes: '100vw',
                widths: '375, 750, 1100, 1500, 1920'
            }}
          {% else %}
            <div class="pookie-hero__placeholder">
              {{ 'lifestyle-1' | placeholder_svg_tag: 'pookie-hero__placeholder-svg' }}
            </div>
          {% endif %}
        </div>

        <div
          class="pookie-hero__overlay"
          style="opacity: {{ block.settings.overlay | times: 0.01 }}"
        ></div>

        <div class="pookie-hero__content pookie-hero__content--{{ block.settings.position }}">
          <div class="pookie-hero__content-inner">
            {% if block.settings.subheading != blank %}
              <span class="pookie-hero__sub">{{ block.settings.subheading }}</span>
            {% endif %}

            {% if block.settings.heading != blank %}
              <h2 class="pookie-hero__title">{{ block.settings.heading }}</h2>
            {% endif %}

            {% if block.settings.cta_text != blank %}
              <a
                href="{{ block.settings.cta_link }}"
                class="pookie-hero__cta {% if block.settings.cta_style == 'outline' %}pookie-hero__cta--outline{% endif %}"
              >
                {{- block.settings.cta_text -}}
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  {% if section.blocks.size > 1 %}
    <button
      class="pookie-hero__arrow pookie-hero__arrow--prev"
      aria-label="{{ 'sections.pookie_hero.previous' | t }}"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M15 4L7 12L15 20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <button
      class="pookie-hero__arrow pookie-hero__arrow--next"
      aria-label="{{ 'sections.pookie_hero.next' | t }}"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M9 4L17 12L9 20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="pookie-hero__dots" role="tablist">
      {% for block in section.blocks %}
        <button
          class="pookie-hero__dot {% if forloop.first %}is-active{% endif %}"
          data-index="{{ forloop.index0 }}"
          role="tab"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          aria-label="{{ 'sections.pookie_hero.go_to_slide' | t: number: forloop.index }}"
        ></button>
      {% endfor %}
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .pookie-hero {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .pookie-hero__slider {
    position: relative;
    width: 100%;
    height: 70vh;
    min-height: 400px;
    max-height: 720px;
  }

  .pookie-hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.8s ease;
    z-index: 0;
  }

  .pookie-hero__slide.is-active {
    opacity: 1;
    z-index: 1;
  }

  .pookie-hero__media {
    position: absolute;
    inset: 0;
  }

  .pookie-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pookie-hero__placeholder {
    width: 100%;
    height: 100%;
    background: #e8e0d8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pookie-hero__placeholder-svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .pookie-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.1) 100%);
    z-index: 1;
    pointer-events: none;
  }

  .pookie-hero__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    padding: 2rem;
  }

  .pookie-hero__content--center {
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .pookie-hero__content--left {
    align-items: center;
    justify-content: flex-start;
    text-align: left;
  }

  .pookie-hero__content--right {
    align-items: center;
    justify-content: flex-end;
    text-align: right;
  }

  .pookie-hero__content--bottom-left {
    align-items: flex-end;
    justify-content: flex-start;
    text-align: left;
  }

  .pookie-hero__content-inner {
    max-width: 600px;
    padding: 1.5rem;
  }

  .pookie-hero__sub {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 0.75rem;
    opacity: 0;
    transform: translateY(15px);
    animation: pookieSlideUp 0.6s ease forwards 0.2s;
  }

  .pookie-hero__title {
    font-size: clamp(1.8rem, 5vw, 3.5rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.15;
    margin: 0 0 1.25rem;
    opacity: 0;
    transform: translateY(15px);
    animation: pookieSlideUp 0.6s ease forwards 0.35s;
  }

  .pookie-hero__cta {
    display: inline-block;
    padding: 0.85rem 2.2rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: #1a1a1a;
    background: #fff;
    border: 2px solid #fff;
    border-radius: 0;
    transition: all 0.3s ease;
    opacity: 0;
    transform: translateY(15px);
    animation: pookieSlideUp 0.6s ease forwards 0.5s;
  }

  .pookie-hero__cta:hover {
    background: transparent;
    color: #fff;
  }

  .pookie-hero__cta--outline {
    background: transparent;
    color: #fff;
  }

  .pookie-hero__cta--outline:hover {
    background: #fff;
    color: #1a1a1a;
  }

  @keyframes pookieSlideUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .pookie-hero__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 50%;
    color: #fff;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .pookie-hero__arrow:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .pookie-hero__arrow--prev {
    left: 1.5rem;
  }

  .pookie-hero__arrow--next {
    right: 1.5rem;
  }

  .pookie-hero__dots {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: 0.6rem;
  }

  .pookie-hero__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid #fff;
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }

  .pookie-hero__dot.is-active {
    background: #fff;
    width: 28px;
    border-radius: 5px;
  }

  @media (max-width: 749px) {
    .pookie-hero__slider {
      height: 55vh;
      min-height: 320px;
    }

    .pookie-hero__content {
      padding: 1.25rem;
      align-items: flex-end !important;
      justify-content: center !important;
      text-align: center !important;
    }

    .pookie-hero__content-inner {
      padding: 1rem;
    }

    .pookie-hero__title {
      font-size: clamp(1.4rem, 6vw, 2.2rem);
    }

    .pookie-hero__arrow {
      width: 36px;
      height: 36px;
    }

    .pookie-hero__arrow--prev {
      left: 0.75rem;
    }

    .pookie-hero__arrow--next {
      right: 0.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pookie-hero__slide {
      transition: none;
    }
    .pookie-hero__sub,
    .pookie-hero__title,
    .pookie-hero__cta {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    const sections = document.querySelectorAll('.pookie-hero');
    sections.forEach(function (section) {
      const slider = section.querySelector('.pookie-hero__slider');
      if (!slider) return;

      const slides = slider.querySelectorAll('.pookie-hero__slide');
      const dots = section.querySelectorAll('.pookie-hero__dot');
      const prevBtn = section.querySelector('.pookie-hero__arrow--prev');
      const nextBtn = section.querySelector('.pookie-hero__arrow--next');

      if (slides.length <= 1) return;

      let current = 0;
      let interval = null;
      const autoRotate = slider.dataset.autoRotate === 'true';
      const speed = parseInt(slider.dataset.speed, 10) * 1000 || 5000;

      function goTo(index) {
        slides[current].classList.remove('is-active');
        if (dots[current]) {
          dots[current].classList.remove('is-active');
          dots[current].setAttribute('aria-selected', 'false');
        }
        current = (index + slides.length) % slides.length;
        slides[current].classList.add('is-active');
        if (dots[current]) {
          dots[current].classList.add('is-active');
          dots[current].setAttribute('aria-selected', 'true');
        }
      }

      function next() {
        goTo(current + 1);
      }

      function prev() {
        goTo(current - 1);
      }

      function startAuto() {
        if (autoRotate && !interval) {
          interval = setInterval(next, speed);
        }
      }

      function stopAuto() {
        if (interval) {
          clearInterval(interval);
          interval = null;
        }
      }

      if (nextBtn) nextBtn.addEventListener('click', function () { stopAuto(); next(); startAuto(); });
      if (prevBtn) prevBtn.addEventListener('click', function () { stopAuto(); prev(); startAuto(); });

      dots.forEach(function (dot) {
        dot.addEventListener('click', function () {
          stopAuto();
          goTo(parseInt(dot.dataset.index, 10));
          startAuto();
        });
      });

      section.addEventListener('mouseenter', stopAuto);
      section.addEventListener('mouseleave', startAuto);

      var touchStartX = 0;
      slider.addEventListener('touchstart', function (e) {
        touchStartX = e.changedTouches[0].screenX;
        stopAuto();
      }, { passive: true });

      slider.addEventListener('touchend', function (e) {
        var diff = touchStartX - e.changedTouches[0].screenX;
        if (Math.abs(diff) > 50) {
          if (diff > 0) { next(); } else { prev(); }
        }
        startAuto();
      }, { passive: true });

      startAuto();
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.pookie_hero.name",
  "tag": "section",
  "class": "pookie-hero-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "t:sections.pookie_hero.settings.auto_rotate",
      "default": true
    },
    {
      "type": "range",
      "id": "speed",
      "label": "t:sections.pookie_hero.settings.speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:sections.pookie_hero.blocks.slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.pookie_hero.settings.image"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "t:sections.pookie_hero.settings.subheading",
          "default": "New collection"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.pookie_hero.settings.heading",
          "default": "Pookie Style"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "t:sections.pookie_hero.settings.cta_text",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "t:sections.pookie_hero.settings.cta_link"
        },
        {
          "type": "select",
          "id": "cta_style",
          "label": "t:sections.pookie_hero.settings.cta_style",
          "options": [
            { "value": "solid", "label": "t:sections.pookie_hero.options.solid" },
            { "value": "outline", "label": "t:sections.pookie_hero.options.outline" }
          ],
          "default": "solid"
        },
        {
          "type": "select",
          "id": "position",
          "label": "t:sections.pookie_hero.settings.position",
          "options": [
            { "value": "center", "label": "t:sections.pookie_hero.options.center" },
            { "value": "left", "label": "t:sections.pookie_hero.options.left" },
            { "value": "right", "label": "t:sections.pookie_hero.options.right" },
            { "value": "bottom-left", "label": "t:sections.pookie_hero.options.bottom_left" }
          ],
          "default": "center"
        },
        {
          "type": "range",
          "id": "overlay",
          "label": "t:sections.pookie_hero.settings.overlay",
          "min": 0,
          "max": 80,
          "step": 5,
          "unit": "%",
          "default": 30
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.pookie_hero.name",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "heading": "New arrivals",
            "subheading": "Spring collection",
            "cta_text": "Shop now",
            "position": "center",
            "overlay": 30
          }
        },
        {
          "type": "slide",
          "settings": {
            "heading": "Ethnic elegance",
            "subheading": "Handpicked kurti & cord sets",
            "cta_text": "Explore",
            "position": "left",
            "overlay": 35
          }
        },
        {
          "type": "slide",
          "settings": {
            "heading": "Flat 20% off",
            "subheading": "Limited time offer",
            "cta_text": "Grab the deal",
            "cta_style": "outline",
            "position": "center",
            "overlay": 40
          }
        }
      ]
    }
  ]
}
{% endschema %}
